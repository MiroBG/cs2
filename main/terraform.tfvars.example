# Example Terraform variables file
# Copy this to terraform.tfvars and customize the values
# terraform.tfvars is gitignored for security

# VPC and networking
main_vpc_cidr       = "10.0.0.0/16"
spoke_vpc_cidr      = "10.1.0.0/16"
environment         = "production"

# EC2 instances
instance_type       = "t3.small"
ami_owner           = "amazon"
ami_name            = "al2023-ami-*"

# RDS database
db_allocated_storage = 20
db_instance_class    = "db.t3.micro"
db_name              = "cs1db"
db_username          = "postgres"
db_password          = "ChangeMe123!"  # Change this!

# Grafana (monitoring)
grafana_admin_user     = "admin"
grafana_admin_password = "admin1234"    # Change this!

# S3 storage
s3_bucket_name_prefix = "cs1-storage"
s3_force_destroy      = false

# Tags
tags = {
  Project     = "CS1"
  ManagedBy   = "Terraform"
  Environment = "production"
}
